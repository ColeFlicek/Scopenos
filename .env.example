ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Scopenos API key — generated at first signup via POST /api/signup.
# Set this here AND in .mcp.json headers so both the benchmark runner
# and the Claude Code MCP connection stay in sync after a DB reset.
SCOPENOS_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL     → production only. Used by the Scopenos server process.
#                    Never set this in a test environment.
# TEST_DATABASE_URL → test suite only. Must point to a separate, throwaway DB.
#                    The test fixture TRUNCATEs this DB before every test.
#
# If DATABASE_URL is set without TEST_DATABASE_URL the test suite will refuse
# to start. If both are set and they resolve to the same host+dbname the test
# suite will also refuse to start.
#
# Run scripts/setup_db_isolation.sh (as postgres superuser) to enforce
# isolation at the Postgres level: the test user loses CONNECT on the prod DB,
# so even a misconfigured URL is refused by the server.
DATABASE_URL=postgresql://acip:...@host/acip
TEST_DATABASE_URL=postgresql://scopenos:scopenos@localhost/scopenos_test

# Embedding model — choose a provider and model
# Provider: openai (default) or ollama
EMBEDDING_PROVIDER=openai

# Model name. Defaults: openai→text-embedding-3-small, ollama→nomic-embed-code
# EMBEDDING_MODEL=text-embedding-3-small

# Vector dimensions. Auto-detected for known models.
# EMBEDDING_DIM=1536

# Ollama base URL (only used when EMBEDDING_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
